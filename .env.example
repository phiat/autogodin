# Copy to .env (gitignored) and adjust for your machine. The justfile
# auto-loads .env if present.

# Odin build flags. Default in justfile: -o:speed.
# Debug builds: ODIN_OPT="-debug -define:ODIN_DISABLE_ASSERT=false"
ODIN_OPT=-o:speed

# Test runner flags. -debug enables Odin's memory tracker.
ODIN_TEST_OPT=-debug

# Single-test smoke target (used by `just smoke`).
# Any test name from odin/tests — e.g. go_game_test.do_move_undo_round_trip.
SMOKE_TEST=do_undo_simple_place

# Sibling clone of upstream autogo (for cross-language parity work).
# Leave unset if you don't have autogo built locally.
AUTOGO_DIR=
